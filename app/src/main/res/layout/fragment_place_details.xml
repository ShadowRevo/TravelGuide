<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/img_place"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_place_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Place Name"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/general_description_fallback"
                android:textSize="15sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_hours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hours: ..."
                android:textColor="#444444"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_fee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fee: ..."
                android:textColor="#444444"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Address: ..."
                android:textColor="#444444"
                android:layout_marginBottom="12dp" />

            <Spinner
                android:id="@+id/spinner_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_read_description"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#673AB7"
                android:text="Read Description"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_translate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#D32F2F"
                android:text="Translate Details"
                android:textColor="#FFFFFF" />


            <Button
                android:id="@+id/btn_map"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Open StreetMap"
                android:backgroundTint="#05A058"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_fav"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Add / Remove Favorite"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btn_view_reviews"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="View Reviews"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btn_add_review"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Write a Review"
                android:backgroundTint="#05A058"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>