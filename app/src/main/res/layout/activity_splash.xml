<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background_gradient">

    <View
        android:id="@+id/orb_top"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-70dp"
        android:layout_marginTop="-30dp"
        android:background="@drawable/splash_orb" />

    <View
        android:id="@+id/orb_bottom"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-90dp"
        android:layout_marginBottom="-70dp"
        android:background="@drawable/splash_orb" />

    <LinearLayout
        android:id="@+id/panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:background="@drawable/splash_glass_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="30dp"
        android:paddingBottom="34dp">

        <FrameLayout
            android:id="@+id/logo_container"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/splash_logo_disc"
            android:foregroundGravity="center"
            android:padding="20dp">

            <ImageView
                android:id="@+id/logo_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Travel guide logo"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="#FFFFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            android:text="Travel Guide"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/tv_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Your passport to hidden gems\nand unforgettable moments"
            android:textColor="#E6FFFFFF"
            android:textSize="15sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_powered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="34dp"
        android:alpha="0.82"
        android:text="Discover • Save • Explore"
        android:textAllCaps="true"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp" />

</FrameLayout>